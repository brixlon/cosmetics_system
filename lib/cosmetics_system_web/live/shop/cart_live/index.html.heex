<div class="shop-page">
  <div class="shop-hero-card">
    <.icon name="hero-shopping-cart" class="w-12 h-12 mb-4 opacity-80" />
    <h1 class="shop-page-title">Shopping cart</h1>
    <p class="shop-page-sub max-w-lg">
      Your bag will sync across sessions and support promo codes before checkout. Hook this LiveView to your cart context when persistence is ready.
    </p>
    <.link navigate={~p"/shop/products"} class="btn btn--primary mt-6">Continue shopping</.link>
  </div>
</div>
