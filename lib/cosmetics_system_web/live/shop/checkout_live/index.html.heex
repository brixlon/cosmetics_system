<div class="shop-page">
  <div class="shop-hero-card">
    <.icon name="hero-credit-card" class="w-12 h-12 mb-4 opacity-80" />
    <h1 class="shop-page-title">Checkout</h1>
    <p class="shop-page-sub max-w-lg">
      Shipping, M-Pesa or card capture, and order confirmation will flow through this step. Placeholder layout keeps spacing and typography aligned with the shop.
    </p>
    <.link navigate={~p"/shop/cart"} class="btn btn--ghost mt-4">Return to cart</.link>
  </div>
</div>
